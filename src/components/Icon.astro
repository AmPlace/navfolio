---
import { Icon as AstroIcon } from 'astro-icon/components';
import type { HTMLAttributes } from 'astro/types';

interface Props extends Omit<HTMLAttributes<'svg'>, 'name' | 'size'> {
  name: string;
  size?: number | string;
  class?: string;
}

const { name, size = 20, class: className, style, ...attrs } = Astro.props;

// Backward compatibility for existing theme configuration and component calls.
// New configuration can use any installed Iconify icon directly, such as
// `lucide:mail` or `simple-icons:telegram`.
const legacyAliases = {
  bilibili: 'simple-icons:bilibili',
  book: 'lucide:book-open',
  'book-open-check': 'lucide:book-open-check',
  branch: 'lucide:git-branch',
  briefcase: 'lucide:briefcase-business',
  building: 'lucide:building-2',
  calendar: 'lucide:calendar-days',
  clock: 'lucide:clock-3',
  'chevron-down': 'lucide:chevron-down',
  commit: 'lucide:git-commit-horizontal',
  compass: 'lucide:compass',
  copy: 'lucide:copy',
  external: 'lucide:external-link',
  folder: 'lucide:folder-open',
  github: 'simple-icons:github',
  juejin: 'simple-icons:juejin',
  layers: 'lucide:layers-3',
  link: 'lucide:link-2',
  linkedin: 'lucide:linkedin',
  mail: 'lucide:mail',
  map: 'lucide:map-pin',
  mastodon: 'simple-icons:mastodon',
  qq: 'simple-icons:qq',
  rss: 'lucide:rss',
  pen: 'lucide:pen-line',
  'pen-tool': 'lucide:pen-tool',
  'pencil-sparkles': 'lucide:pencil-line',
  repo: 'lucide:book-marked',
  sparkle: 'lucide:sparkles',
  star: 'lucide:star',
  tags: 'lucide:tags',
  twitter: 'lucide:twitter',
  wechat: 'simple-icons:wechat',
  weibo: 'simple-icons:sinaweibo',
  x: 'simple-icons:x',
  xiaohongshu: 'simple-icons:xiaohongshu',
  zhihu: 'simple-icons:zhihu',
  pin: 'lucide:pin',
} as const;

const resolvedName = name.includes(':')
  ? name
  : (legacyAliases[name as keyof typeof legacyAliases] ?? `lucide:${name}`);
const isBrandIcon = resolvedName.startsWith('simple-icons:');
const iconSize = typeof size === 'number' ? `${size}px` : size;
const iconStyle = `--icon-size: ${iconSize};${style ? ` ${style}` : ''}`;
---

<AstroIcon
  {...attrs}
  name={resolvedName}
  size={size}
  stroke-width={attrs['stroke-width'] ?? (isBrandIcon ? undefined : 1.9)}
  aria-hidden={attrs['aria-hidden'] ?? 'true'}
  focusable={attrs.focusable ?? 'false'}
  style={iconStyle}
  class:list={['site-icon', { 'site-icon--brand': isBrandIcon }, className]}
/>
