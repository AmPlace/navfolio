---
import { getCollection } from 'astro:content';
import { getSiteConfig } from '../../data/site';
import { getAllCategories, getAllSeries, getAllTags } from '../../utils/content-groups';
import { getUiText } from '../../utils/ui-text';

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = await getCollection('blog', ({ data }) => !data.draft);
const categories = getAllCategories(posts);
const seriesCount = getAllSeries(posts).length;
const tagCount = getAllTags(posts).length;
const yearsCount = new Set(posts.map((post) => post.data.date.getFullYear())).size;
const ui = getUiText(await getSiteConfig());

function withBase(href: string) {
  return `${basePath}${href}`;
}
---

<nav class="group-nav" aria-label={ui.groups.blogBrowsingGroups} data-group-nav>
  <div class="topic-panel">
    <div class="topic-list" data-topic-list>
      <a class="topic-chip is-active" href={withBase('/blog/')}>
        <span>全部文章</span>
        <b>{posts.length}</b>
      </a>
      {
        categories.map((category) => (
          <a class="topic-chip" href={withBase(`/blog/categories/${category.slug}/`)}>
            <span>{category.name}</span>
            <b>{category.count}</b>
          </a>
        ))
      }
    </div>
    {
      categories.length > 5 && (
        <button class="topic-toggle" type="button" data-topic-toggle aria-expanded="false">
          <span data-topic-toggle-label>展开</span>
        </button>
      )
    }
  </div>

  <div class="group-links" aria-label="Blog views">
    <a href={withBase('/blog/series/')}>系列</a>
    <span aria-hidden="true">·</span>
    <a href={withBase('/blog/tags/')}>标签</a>
    <span aria-hidden="true">·</span>
    <a href={withBase('/blog/archives/')}>年份</a>
  </div>

  <span class="group-counts" aria-hidden="true">
    {seriesCount} / {tagCount} / {yearsCount}
  </span>
</nav>

<script is:inline>
  (() => {
    document.querySelectorAll('[data-group-nav]').forEach((nav) => {
      const list = nav.querySelector('[data-topic-list]');
      const toggle = nav.querySelector('[data-topic-toggle]');
      const label = nav.querySelector('[data-topic-toggle-label]');

      if (!(list instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement)) return;

      toggle.addEventListener('click', () => {
        const expanded = nav.classList.toggle('is-expanded');
        toggle.setAttribute('aria-expanded', String(expanded));

        if (label) {
          label.textContent = expanded ? '收起' : '展开';
        }
      });
    });
  })();
</script>

<style>
  .group-nav {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px 28px;
    align-items: start;
    margin: calc(var(--page-header-spacing) * -0.45) 0 34px;
    padding: 0;
  }

  .topic-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
    min-width: 0;
    padding-right: 28px;
    border-right: 1px solid var(--paper-line);
  }

  .topic-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    max-height: 38px;
    overflow: hidden;
  }

  .group-nav.is-expanded .topic-list {
    max-height: none;
    overflow: visible;
  }

  .topic-chip,
  .topic-toggle {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    border: 1px solid var(--paper-line);
    border-radius: 6px;
    background: color-mix(in srgb, var(--paper-control) 72%, transparent);
    color: var(--paper-ink-soft);
    font-family: var(--font-meta);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .topic-chip {
    gap: 9px;
    padding: 0 12px;
  }

  .topic-chip:hover,
  .topic-toggle:hover {
    border-color: var(--paper-line-strong);
    background: var(--paper-control-hover);
    color: var(--paper-ink);
    transform: translateY(-1px);
  }

  .topic-chip.is-active {
    border-color: color-mix(in srgb, var(--paper-accent) 28%, var(--paper-line));
    background: var(--paper-surface);
    color: var(--paper-accent);
  }

  .topic-chip.is-active::before {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: currentColor;
    content: '';
  }

  .topic-chip b {
    color: var(--paper-ink-faint);
    font-size: 0.75rem;
  }

  .topic-toggle {
    justify-content: center;
    padding: 0 12px;
    cursor: pointer;
  }

  .group-links {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    min-height: 36px;
    padding-top: 1px;
    color: var(--paper-ink-faint);
    font-family: var(--font-meta);
    font-size: 0.9rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .group-links a {
    color: var(--paper-ink);
    text-decoration: underline;
    text-decoration-color: var(--paper-line-strong);
    text-underline-offset: 5px;
    transition:
      color 180ms ease,
      text-decoration-color 180ms ease;
  }

  .group-links a:hover {
    color: var(--paper-accent);
    text-decoration-color: currentColor;
  }

  .group-counts {
    display: none;
  }

  @media (max-width: 760px) {
    .group-nav {
      grid-template-columns: 1fr;
      gap: 12px;
      margin-top: -10px;
    }

    .topic-panel {
      padding-right: 0;
      padding-bottom: 12px;
      border-right: 0;
      border-bottom: 1px solid var(--paper-line);
    }

    .topic-list {
      max-height: 84px;
    }

    .group-links {
      justify-content: flex-start;
    }
  }
</style>
