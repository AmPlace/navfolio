---
import { getCollection } from 'astro:content';
import { getSiteConfig } from '../../data/site';
import {
  getAllCategories,
  getAllSeries,
  getAllTags,
  uncategorizedCategory,
} from '../../utils/content-groups';
import { getUiText } from '../../utils/ui-text';

interface Props {
  activeView?: 'posts' | 'series' | 'tags' | 'archives';
  activeCategory?: string;
}

const { activeView = 'posts', activeCategory } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = await getCollection('blog', ({ data }) => !data.draft);
const categories = getAllCategories(posts);
const seriesCount = getAllSeries(posts).length;
const tagCount = getAllTags(posts).length;
const yearsCount = new Set(posts.map((post) => post.data.date.getFullYear())).size;
const ui = getUiText(await getSiteConfig());

function withBase(href: string) {
  return `${basePath}${href}`;
}

function getCategoryName(name: string, slug: string) {
  return slug === uncategorizedCategory.slug ? ui.groups.uncategorized : name;
}
---

<nav class="group-nav" aria-label={ui.groups.blogBrowsingGroups} data-group-nav>
  <div class="topic-panel">
    <div class="topic-list" data-topic-list>
      <a
        class:list={['topic-chip', activeView === 'posts' && !activeCategory && 'is-active']}
        href={withBase('/blog/')}
      >
        <span>{ui.groups.allArticles}</span>
        <b>{posts.length}</b>
      </a>
      {
        categories.map((category) => (
          <a
            class:list={[
              'topic-chip',
              activeView === 'posts' && activeCategory === category.slug && 'is-active',
            ]}
            href={withBase(`/blog/categories/${category.slug}/`)}
          >
            <span>{getCategoryName(category.name, category.slug)}</span>
            <b>{category.count}</b>
          </a>
        ))
      }
    </div>
    {
      categories.length > 5 && (
        <button
          class="topic-toggle"
          type="button"
          data-topic-toggle
          data-expand-label={ui.groups.expand}
          data-collapse-label={ui.groups.collapse}
          aria-expanded="false"
        >
          <span data-topic-toggle-label>{ui.groups.expand}</span>
        </button>
      )
    }
  </div>

  <div class="group-links" aria-label="Blog views">
    <a class:list={[activeView === 'series' && 'is-active']} href={withBase('/blog/series/')}>
      {ui.groups.series}
    </a>
    <span aria-hidden="true">·</span>
    <a class:list={[activeView === 'tags' && 'is-active']} href={withBase('/blog/tags/')}>
      {ui.groups.tags}
    </a>
    <span aria-hidden="true">·</span>
    <a class:list={[activeView === 'archives' && 'is-active']} href={withBase('/blog/archives/')}>
      {ui.groups.years}
    </a>
  </div>

  <span class="group-counts" aria-hidden="true">
    {seriesCount} / {tagCount} / {yearsCount}
  </span>
</nav>

<script>
  import { mountGroupNav } from '../../utils/group-nav';

  mountGroupNav();
</script>

<style>
  .group-nav {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px 28px;
    align-items: start;
    margin: calc(var(--page-header-spacing) * -0.45) 0 34px;
    padding: 0;
  }

  .topic-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
    min-width: 0;
    padding-right: 28px;
    border-right: 1px solid var(--paper-line);
  }

  .topic-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    max-height: 42px;
    margin-top: -2px;
    padding: 2px 0;
    overflow: hidden;
  }

  .group-nav.is-expanded .topic-list {
    max-height: none;
    overflow: visible;
  }

  .topic-chip,
  .topic-toggle {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    border: 1px solid var(--paper-line);
    border-radius: 6px;
    background: color-mix(in srgb, var(--paper-control) 72%, transparent);
    color: var(--paper-ink-soft);
    font-family: var(--font-meta);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .topic-chip {
    gap: 9px;
    padding: 0 12px;
  }

  .topic-chip:hover,
  .topic-toggle:hover {
    border-color: var(--paper-line-strong);
    background: var(--paper-control-hover);
    color: var(--paper-ink);
    transform: translateY(-1px);
  }

  .topic-chip.is-active {
    border-color: color-mix(in srgb, var(--paper-accent) 28%, var(--paper-line));
    background: var(--paper-surface);
    color: var(--paper-accent);
  }

  .topic-chip.is-active::before {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: currentColor;
    content: '';
  }

  .topic-chip b {
    color: var(--paper-ink-faint);
    font-size: 0.75rem;
  }

  .topic-toggle {
    justify-content: center;
    padding: 0 12px;
    cursor: pointer;
  }

  .group-links {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    min-height: 36px;
    padding-top: 1px;
    color: var(--paper-ink-faint);
    font-family: var(--font-meta);
    font-size: 0.9rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .group-links a {
    color: var(--paper-ink);
    text-decoration: underline;
    text-decoration-color: var(--paper-line-strong);
    text-underline-offset: 5px;
    transition:
      color 180ms ease,
      text-decoration-color 180ms ease;
  }

  .group-links a:hover,
  .group-links a.is-active {
    color: var(--paper-accent);
    text-decoration-color: currentColor;
  }

  .group-counts {
    display: none;
  }

  @media (max-width: 760px) {
    .group-nav {
      grid-template-columns: 1fr;
      gap: 12px;
      margin-top: -10px;
    }

    .topic-panel {
      padding-right: 0;
      padding-bottom: 12px;
      border-right: 0;
      border-bottom: 1px solid var(--paper-line);
    }

    .topic-list {
      max-height: 88px;
    }

    .group-links {
      justify-content: flex-start;
    }
  }
</style>
